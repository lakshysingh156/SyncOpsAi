# ---- SyncOps AI environment ----
# Copy to .env and fill in. Never commit real secrets.

# App
ENVIRONMENT=development
DEBUG=true

# Database (async SQLAlchemy URL). For docker-compose use the service host `db`.
DATABASE_URL=postgresql+asyncpg://syncops:syncops@db:5432/syncops

# CORS (JSON array)
CORS_ORIGINS=["http://localhost:3000"]

# Ingestion auth — clients must send this as the X-API-Key header
INGEST_API_KEY=dev-ingest-key

# Gemini (used from Milestone 5 onward)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_RCA_MODEL=gemini-1.5-pro
GEMINI_EMBEDDING_MODEL=text-embedding-004
EMBEDDING_DIM=768

# Frontend (used by Next.js rewrites)
BACKEND_URL=http://localhost:8000
